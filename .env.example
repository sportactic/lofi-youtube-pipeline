# Lofi YouTube Pipeline — Environment Variables
# Copy this file to .env, fill in real values, and source it before running the pipeline:
#   cp .env.example .env
#   set -a && source .env && set +a
#   python pipeline/main.py --full

# === Suno.com ===
# Get this from your browser: open https://suno.com while logged in,
# then F12 → Application → Cookies → https://suno.com → find "__client" → copy its Value
SUNO_COOKIE=

# === MiniMax (MiniMax) ===
# Get from your MiniMax account dashboard: Settings → API Keys
MINIMAX_API_KEY=

# === YouTube ===
# Get from Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client IDs → Download JSON
# Then paste the FULL file contents on a single line:
YOUTUBE_CLIENT_SECRETS_JSON=
# Where the script will write it. Default is the current working directory.
YOUTUBE_CLIENT_SECRETS_FILE=./client_secrets.json
# Your channel handle (used for metadata; the upload itself goes to the OAuth-authenticated account)
YOUTUBE_CHANNEL_HANDLE=@The-Lo-Fi
# Optional: refresh token if you already completed the OAuth flow once
# (auto-populated on first run from token.json)
YOUTUBE_REFRESH_TOKEN=
